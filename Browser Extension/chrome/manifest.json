{
  "manifest_version": 3,
  "name": "Fast Native Download Manager",
  "description": "Intercept downloads and send links to Fast Native Download Manager from Chrome.",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "contextMenus",
    "cookies",
    "downloads",
    "notifications",
    "scripting",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://127.0.0.1:51237/*",
    "http://localhost:51237/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Fast Native Download Manager",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "minimum_chrome_version": "114"
}
